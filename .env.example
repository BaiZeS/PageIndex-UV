# ---------------------------------------------------------------------------
# PageIndex-UV environment template
# Copy to `.env` (which is gitignored) and fill in real values.
# `.env.example` itself is intentionally committable — it ships placeholders only.
# ---------------------------------------------------------------------------

# ===========================================================================
# LLM credentials
# ---------------------------------------------------------------------------
# Key priority (highest wins): explicit arg > OPENAI_API_KEY > DASHSCOPE_API_KEY
# > CHATGPT_API_KEY (legacy alias, auto-copied to OPENAI_API_KEY when set).
#
# OpenAI is the default provider; DashScope (Qwen) is the alternative.
# To switch to DashScope, comment out OPENAI_API_KEY, uncomment
# DASHSCOPE_API_KEY below, and set MODEL_NAME=qwen-plus.
# ===========================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Overrides the LLM endpoint for either provider when set.
# When commented, utils.py defaults to the standard OpenAI endpoint
# (https://api.openai.com/v1).
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- DashScope provider alternative (commented out) -------------------------
# Uncomment and set these to use the DashScope (Qwen) compatible-mode endpoint
# instead of OpenAI. Remember to comment out OPENAI_API_KEY above and set
# MODEL_NAME=qwen-plus.
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Legacy alias: if CHATGPT_API_KEY is set, it is auto-copied to OPENAI_API_KEY
# by _resolve_llm_config. Leave commented unless migrating an old deployment.
# CHATGPT_API_KEY=sk-xxxxxxxxxxxxxxxx  # legacy alias, auto-copied to OPENAI_API_KEY when set

# ===========================================================================
# Model names
# ---------------------------------------------------------------------------
# MODEL_NAME            overrides `model`            in config.yaml
# RETRIEVE_MODEL_NAME   overrides `retrieve_model`   in config.yaml
#
# Precedence (highest wins):
#   1. caller-explicit kwarg to ConfigLoader().load({...})
#   2. MODEL_NAME / RETRIEVE_MODEL_NAME env vars
#   3. config.yaml defaults (model / retrieve_model)
#
# This is the ONE resolution path shared by the CLI (main.py) and the server
# (server.py -> PageIndexClient -> ConfigLoader), so MODEL_NAME now takes
# effect in ALL paths. When RETRIEVE_MODEL_NAME is unset, retrieve_model uses
# the config.yaml default. In the server path (PageIndexClient), an empty
# retrieve_model additionally falls back to the resolved model.
# ===========================================================================
MODEL_NAME=gpt-4.1-mini
# Optional: set a retrieval/embedding model independently of MODEL_NAME.
# RETRIEVE_MODEL_NAME=text-embedding-v3

# ===========================================================================
# Server runtime  (docker / local server)
# ---------------------------------------------------------------------------
# API_KEY    HTTP request authentication for the MCP service (NOT the LLM key).
# HOST/PORT  bind address for server.py.
# WORKSPACE  directory where indexed documents are stored.
# DB_PATH    SQLite index database path.
# ===========================================================================
API_KEY=changeme
HOST=0.0.0.0
PORT=3000
WORKSPACE=/app/data/workspace
DB_PATH=/app/data/index.db
